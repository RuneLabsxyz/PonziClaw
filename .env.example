# PonziLand API base (expects /price)
PUBLIC_PONZI_API_URL=https://play.ponzis.fun

# Torii base (expects /sql)
PUBLIC_DOJO_TORII_URL=https://api.cartridge.gg/x/ponziland-mainnet-world-new/torii

# Optional SQL for flow signal (must return JSON-serializable result)
PONZI_FLOW_SQL=SELECT COUNT(*) AS tx_count FROM events LIMIT 1

# Optional placeholders used when emitting calls JSON
PONZI_CONTRACT_ADDRESS=0x0
PONZI_ENTRYPOINT=play
