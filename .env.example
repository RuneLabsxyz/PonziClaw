# Mainnet defaults from PonziLand repo config
PUBLIC_DOJO_TORII_URL=https://api.cartridge.gg/x/ponziland-mainnet-world-new/torii
PUBLIC_PONZI_API_URL=https://api.runelabs.xyz/ponziland-mainnet-temp/api

# Manifest/token metadata shipped with this skill
PONZI_TOKENS_CONFIG=references/mainnet.tokens.json
PONZI_MANIFEST_PATH=references/manifest_mainnet.json

# Optional strategy SQL override for flow proxy
PONZI_FLOW_SQL=SELECT COUNT(*) AS tx_count FROM event_messages_historical LIMIT 1

# Optional starter call defaults for strategy -> execute payload
PONZI_DEFAULT_LAND_LOCATION=1
PONZI_DEFAULT_SELL_PRICE_WEI=1000000000000000000
PONZI_DEFAULT_STAKE_WEI=10000000000000000
